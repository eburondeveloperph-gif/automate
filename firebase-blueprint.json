{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "Memory": {
      "title": "Memory",
      "description": "Information stored by Beatrice about the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["preference", "fact", "summary"] },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "content", "type", "createdAt", "updatedAt"]
    },
    "UploadedFile": {
      "title": "UploadedFile",
      "description": "Metadata for files uploaded to Beatrice",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "filename": { "type": "string" },
        "mimeType": { "type": "string" },
        "size": { "type": "number" },
        "storageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "filename", "mimeType", "size", "storageUrl", "createdAt"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "A single piece of conversation between Jo and Beatrice",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["jo", "beatrice"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "timestamp" },
        "context": { "type": "string" }
      },
      "required": ["userId", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles. Id is the Firebase Auth UID."
    },
    "users/{userId}/memories/{memoryId}": {
      "schema": { "$ref": "#/entities/Memory" },
      "description": "Memories owned by the specific user."
    },
    "users/{userId}/files/{fileId}": {
      "schema": { "$ref": "#/entities/UploadedFile" },
      "description": "Uploaded file metadata owned by the user."
    },
    "users/{userId}/interactions/{interactionId}": {
      "schema": { "$ref": "#/entities/Interaction" },
      "description": "Searchable conversation logs."
    }
  }
}
